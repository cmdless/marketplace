{
    "$schema": "https://typeforged.github.io/schema.registry/codex-plugin-marketplace/v1/marketplace.schema.json",
    "name": "cmdless-marketplace",
    "plugins": [
        {
            "name": "spark",
            "source": {
                "source": "git-subdir",
                "url": "https://github.com/github/copilot-plugins.git",
                "path": "./plugins/spark",
                "ref": "main"
            },
            "policy": {
                "installation": "AVAILABLE",
                "authentication": "ON_INSTALL"
            },
            "category": "cmdless"
        },
        {
            "name": "electron-skills",
            "source": {
                "source": "url",
                "url": "https://github.com/full-stack-skills/electron-skills.git",
                "ref": "main"
            },
            "policy": {
                "installation": "AVAILABLE",
                "authentication": "ON_INSTALL"
            },
            "category": "cmdless"
        },
        {
            "name": "dotnet-skills",
            "source": {
                "source": "url",
                "url": "https://github.com/dotnet/skills.git",
                "ref": "main"
            },
            "policy": {
                "installation": "AVAILABLE",
                "authentication": "ON_INSTALL"
            },
            "category": "cmdless"
        }
    ]
}